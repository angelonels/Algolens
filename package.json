{
  "name": "algolens",
  "version": "1.0.0",
  "description": "See how algorithms actually work — step by step, right in your browser.",
  "type": "module",
  "author": "Angelo Nelson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelonels/Algolens.git"
  },
  "bugs": {
    "url": "https://github.com/angelonels/Algolens/issues"
  },
  "homepage": "https://angelonels.github.io/Algolens",
  "keywords": [
    "algorithms",
    "visualization",
    "sorting-algorithms",
    "pathfinding",
    "react",
    "typescript",
    "interactive-learning"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "framer-motion": "^12.9.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.3.1",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  }
}
